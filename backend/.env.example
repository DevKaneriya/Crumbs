# ============================================
# Django Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ============================================
# Django Core Settings
# ============================================

# SECURITY WARNING: Generate a new secret key for production!
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION

# Set to 'false' in production
DEBUG=true

# Comma-separated list of allowed hosts
# Example: yourdomain.com,www.yourdomain.com,api.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# ============================================
# Database Configuration
# ============================================

# SQLite (Development - Default)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL (Production - Recommended)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=crumbs_db
# DB_USER=crumbs_user
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=5432

# MySQL (Alternative)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=crumbs_db
# DB_USER=crumbs_user
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=3306

# ============================================
# Email Configuration
# ============================================

# Set to 'true' to use real email (Gmail SMTP)
# Set to 'false' or leave empty to print emails to console (development)
USE_REAL_EMAIL=false

# Gmail SMTP Settings (only needed when USE_REAL_EMAIL=true)
# Get app password from: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# Email address shown in "From" field (optional, defaults to EMAIL_HOST_USER)
DEFAULT_FROM_EMAIL=noreply@crumbs.com

# ============================================
# CORS and CSRF Configuration
# ============================================

# Comma-separated list of allowed frontend origins
# Production example: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Comma-separated list of trusted origins for CSRF
# Production example: https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ============================================
# Frontend Configuration
# ============================================

# Frontend URL for password reset links
# Development: http://localhost:4200
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:4200

# ============================================
# Razorpay Payment Gateway (Test Mode)
# ============================================
# Get your test keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_KEY_SECRET
# Webhook secret — set this in Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ============================================
# Redis & Celery Configuration
# ============================================

# Redis URL — set this to enable Redis cache and real async task processing
# Leave empty in development to use in-memory cache + synchronous (eager) tasks
# Production example: redis://localhost:6379/0  or  redis://:password@host:6379/0
REDIS_URL=redis://localhost:6379/0

# Celery broker and result backend (point both at your Redis instance)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# Logging
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DJANGO_LOG_LEVEL=INFO
